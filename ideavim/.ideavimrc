"" -- Suggested options --
" Show a few lines of context around the cursor. Note that this makes the
" text scroll if you mouse-click near the start or end of the window.
"
let mapleader=" "
set scrolloff=8

" Do incremental searching.
set incsearch

" Don't use Ex mode, use Q for formatting.
map Q gq

" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins

" Highlight copied text
Plug 'machakann/vim-highlightedyank'
" Commentary plugin
Plug 'tpope/vim-commentary'
Plug 'easymotion/vim-easymotion'

sethandler <j> a:vim
sethandler <k> a:vim
set ideamarks

set surround
set multiple-cursors
set commentary
set argtextobj
set textobj-entire
set ReplaceWithRegister
set relativenumber

map <leader>t <Action>(Refactorings.QuickListPopupAction)

" Paste in visual mode without copying to register
vnoremap p "_dP
vnoremap P "_dP

" Optional: Make x and s also delete to black hole register
nnoremap x "_x
nnoremap s "_s

""" Navigation
nmap <leader>nb <Action>(ShowNavBar)
nmap <leader>e <Action>(RecentFiles)
nmap <leader>ff <Action>(GotoFile)
nmap <leader>fs <Action>(GotoSymbol)
nmap <leader>fg <Action>(FindInPath)

"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"" Map \r to the Reformat Code action
"map \r <Action>(ReformatCode)

"" Map <leader>d to start debug
"map <leader>d <Action>(Debug)

"" Map \b to toggle the breakpoint on the current line
"map \b <Action>(ToggleLineBreakpoint)
